# Copy to ~/.config/timely/config.env (or set TIMELY_HOME).
# Process environment variables override these values.
# Do not put tokens or client secrets here; use auth commands instead.

# OAuth application (public client id)
TIMELY_CLIENT_ID=
# TIMELY_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# Defaults
# TIMELY_ACCOUNT_ID=
# TIMELY_BASE_URL=https://api.timelyapp.com
# TIMELY_TIMEOUT=30
# TIMELY_OUTPUT=auto
# TIMELY_PROFILE=default
# TIMELY_DEBUG=
# TIMELY_NO_COLOR=
# TIMELY_MEMORY_DB=
